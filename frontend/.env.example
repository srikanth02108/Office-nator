# Copy to .env.local for local dev, or set in Vercel dashboard for production
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Same JWT_SECRET as the landing page (validates the auth cookie)
JWT_SECRET=change-this-to-a-random-64-char-hex-string

# Landing page URL — logout redirects here
NEXT_PUBLIC_LANDING_URL=http://localhost:4000