# Sutra — Environment variable template
# Copy to .env and fill in your real keys.

# Sarvam AI — get from https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Gemini — get from https://aistudio.google.com/apikey (fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (PRIMARY — free, fast) — get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Which LLM to use: "groq" (recommended) or "gemini"
LLM_PROVIDER=groq

# n8n webhook (local)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/sutra
